# ─────────────────────────────────────────────────────────────
# IA — Google Gemini
# ─────────────────────────────────────────────────────────────
# GEMINI_API_KEY: chave do Google Gemini. Sem ela, os endpoints de IA usam o
# fallback local (mock) e a aplicação segue utilizável para demonstração.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GEMINI_MODEL: id do modelo usado por toda a IA (ver server/ai/model.ts).
# Confirme o nome no catálogo atual do Google para a sua conta.
GEMINI_MODEL="gemini-2.5-flash"

# APP_URL: URL onde a aplicação está hospedada (links, callbacks).
APP_URL="MY_APP_URL"

# ─────────────────────────────────────────────────────────────
# Supabase — banco de dados + autenticação
# (funciona tanto no Supabase Cloud quanto self-hosted)
# ─────────────────────────────────────────────────────────────
# Públicas (vão para o bundle do front):
VITE_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_ANON_KEY"

# Servidor apenas — NUNCA exponha no front. A URL é reutilizada de
# VITE_SUPABASE_URL; só a service_role é exclusiva do servidor (grava acima da RLS).
# É um JWT (começa com "eyJ") com "role":"service_role" no payload.
SUPABASE_SERVICE_ROLE_KEY="YOUR_SERVICE_ROLE_KEY"
# SUPABASE_URL="https://override-opcional"  # só se o servidor usar outra URL

# ─────────────────────────────────────────────────────────────
# E-mail transacional (Fase 5 — envio real de comunicações)
# ─────────────────────────────────────────────────────────────
EMAIL_PROVIDER=""          # "resend" | "smtp" | ""
RESEND_API_KEY=""
EMAIL_FROM="Recrutamento FIESC <no-reply@exemplo.com>"

# ─────────────────────────────────────────────────────────────
# Integração Benner (Fase 6 — depende de contrato/credenciais do cliente)
# ─────────────────────────────────────────────────────────────
BENNER_BASE_URL=""
BENNER_OAUTH_CLIENT_ID=""
BENNER_OAUTH_CLIENT_SECRET=""
