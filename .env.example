# ============================================================
# ATS Sistema FIESC — variáveis de ambiente (exemplo)
# ============================================================
# Copie para `.env` e preencha. O `.env` real é git-ignored
# (ver .gitignore: `.env*` + `!.env.example`). NUNCA comite segredos.
#
# Sem Supabase e sem Gemini o app roda em MODO DEMO:
#  - dados em memória (seed), sem login, endpoints de IA no fallback local.
# Preencha as chaves abaixo para habilitar auth, persistência e IA real.

# ── Servidor ────────────────────────────────────────────────
# Porta do Express (o Dockerfile já define 3000).
PORT=3000
# Em produção use `production` para servir dist/ em vez do Vite dev middleware.
NODE_ENV=development
# URL pública da aplicação (links/callbacks). Opcional.
APP_URL=http://localhost:3000

# ── IA (Google Gemini) ──────────────────────────────────────
# Sem esta chave, os 6 endpoints de IA usam um fallback local (mock)
# e a aplicação continua utilizável para demonstração.
GEMINI_API_KEY=
# Id do modelo. Padrão: gemini-2.5-flash (ver server/ai/model.ts).
GEMINI_MODEL=gemini-2.5-flash

# ── Supabase — FRONT (públicas, inlinadas no bundle pelo Vite) ──
# As VITE_* são build args: trocá-las exige REBUILD, não só restart.
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=

# ── Supabase — SERVIDOR ─────────────────────────────────────
# SUPABASE_URL é um override opcional; por padrão o servidor reaproveita
# VITE_SUPABASE_URL. A service_role opera ACIMA da RLS e é EXCLUSIVA de
# runtime — NUNCA a use como build arg nem a exponha no front.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── E-mail (Fase posterior) ─────────────────────────────────
# Envio real de comunicações ao candidato. Deixe vazio até haver credenciais.
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=

# ── Integração Benner (Fase posterior) ──────────────────────
# Sincronismo com o ERP/Folha Benner via REST/OAuth2. Deixe vazio por ora.
BENNER_BASE_URL=
BENNER_CLIENT_ID=
BENNER_CLIENT_SECRET=
